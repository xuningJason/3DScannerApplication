<UserControl x:Class="_3DScannerApp.ModeSelectDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:_3DScannerApp"
             mc:Ignorable="d"
             Height="500" Width="400"
             Background="#F6F7FB">

    <Grid Margin="12">
        <Grid.Resources>
            <!-- ===== 主题色（跟主界面一致） ===== -->
            <Color x:Key="PrimaryColor">#2F6FED</Color>
            <Color x:Key="PrimaryHoverColor">#2A62D2</Color>
            <Color x:Key="PrimaryPressedColor">#2456B8</Color>
            <Color x:Key="DangerColor">#E24A4A</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
            <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

            <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DCE6"/>
            <SolidColorBrush x:Key="TextMainBrush" Color="#111111"/>
            <SolidColorBrush x:Key="TextSubBrush" Color="#333333"/>

            <!-- ✅ 行间距的关键：给控件统一 Margin -->
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,4,10,4"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="MinWidth" Value="160"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="#C9CEDA"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <!-- ✅ 每行之间的距离主要靠这个 -->
                <Setter Property="Margin" Value="0,6,0,6"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Margin" Value="0,8,0,8"/>
                <Setter Property="LayoutTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.6" ScaleY="1.6"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ===== 主按钮 ===== -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="12,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryPressedBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryPressedBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#C9CEDA"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#C9CEDA"/>
                                    <Setter Property="Foreground" Value="#F8F8F8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Background" Value="#EEF3FF"/>
                <Setter Property="BorderBrush" Value="#CFE0FF"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="12,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#DDE9FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#CFE0FF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#E7E9EE"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#E7E9EE"/>
                                    <Setter Property="Foreground" Value="#9AA3B2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            </Style>
        </Grid.Resources>

        <Border CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrushSoft}"
                Background="White"
                Padding="14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="扫描模式参数"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMainBrush}"/>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>

                        <!-- ✅ 保留：行命名不删 -->
                        <RowDefinition x:Name="Increment_Row" Height="Auto"/>
                        <RowDefinition x:Name="Delay_Row" Height="Auto"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="扫描起点（°）：" />
                    <TextBox Grid.Row="0" Grid.Column="1" Name="Start_Position" IsEnabled="True"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="扫描终点（°）：" />
                    <TextBox Grid.Row="1" Grid.Column="1" Name="End_Position" IsEnabled="True"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="扫描增量（°）：" />
                    <TextBox Grid.Row="2" Grid.Column="1" Name="Scan_Increment" IsEnabled="True"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="延迟时间（ms）：" />
                    <TextBox Grid.Row="3" Grid.Column="1" Name="Delay_Time" IsEnabled="True"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="保持时间（ms）：" />
                    <TextBox Grid.Row="4" Grid.Column="1" Name="Stay_Time" IsEnabled="True"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="是否触发：" />
                    <CheckBox Grid.Row="5" Grid.Column="1" Name="Trigger_Checkbox"/>

                    <Button Grid.Row="6" Grid.ColumnSpan="2"
                            Content="保存参数"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,10,0,0"
                            Click="Button_Click_2"/>

                    <UniformGrid Grid.Row="7" Grid.ColumnSpan="2"
                                 Columns="2"
                                 Margin="0,10,0,0">
                        <Button Content="开始扫描"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="Button_Click"/>

                        <Button Content="中断扫描"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="Button_Click_1"/>
                    </UniformGrid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
