<UserControl x:Class="_3DScannerApp.CustomMessageBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_3DScannerApp"
             mc:Ignorable="d" 
             Height="140" Width="400" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <TextBlock Text="请选择模式" Margin="10" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0">
            <Button Content="连续触发" Margin="5 2" Height="30" Width="90" FontSize="14" Click="CoiledTrigger"/>
            <Button Content="间隔触发" Margin="5 2" Height="30" Width="90" FontSize="14" Click="IntervalTrigger"/>
        </StackPanel>
    </Grid>
</UserControl>
