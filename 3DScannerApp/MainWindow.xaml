<Window x:Class="_3DScannerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_3DScannerApp"
        mc:Ignorable="d"
        Closed="Window_Closed"
        Title="MainWindow" Height="400" Width="920"
        Background="#F6F7FB">

    <Grid Margin="12">
        <Grid.Resources>

            <!-- ===== 主题色（想换颜色只改这几个） ===== -->
            <Color x:Key="PrimaryColor">#2F6FED</Color>
            <Color x:Key="PrimaryHoverColor">#2A62D2</Color>
            <Color x:Key="PrimaryPressedColor">#2456B8</Color>
            <Color x:Key="DangerColor">#E24A4A</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
            <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
            <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

            <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DCE6"/>
            <SolidColorBrush x:Key="TextMainBrush" Color="#111111"/>
            <SolidColorBrush x:Key="TextSubBrush" Color="#333333"/>
            <SolidColorBrush x:Key="ValueBgBrush" Color="#F1F5FF"/>
            <SolidColorBrush x:Key="ValueBorderBrush" Color="#D6E2FF"/>

            <!-- ===== GroupBox 统一风格 ===== -->
            <Style TargetType="GroupBox">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="14"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
                <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            </Style>

            <Style TargetType="Label">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="#C9CEDA"/>
                <Setter Property="Background" Value="#FFFFFF"/>
            </Style>

            <!-- ===== 读数“卡片”样式（Border + TextBlock） ===== -->
            <Style x:Key="ValueCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ValueBgBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource ValueBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            </Style>

            <!-- ===== 主按钮风格：圆角 + hover/pressed + disabled ===== -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="12,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryPressedBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryPressedBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#C9CEDA"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#C9CEDA"/>
                                    <Setter Property="Foreground" Value="#F8F8F8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 次按钮：浅底（比如“调光”这类不那么关键的操作） -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Background" Value="#EEF3FF"/>
                <Setter Property="BorderBrush" Value="#CFE0FF"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="12,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#DDE9FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#CFE0FF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#E7E9EE"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#E7E9EE"/>
                                    <Setter Property="Foreground" Value="#9AA3B2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左：网络连接 -->
        <GroupBox Grid.Column="0" Header="网络连接">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="网络端口：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" IsEnabled="False" Text="8234"/>

                <Label Grid.Row="2" Grid.Column="0" Content="波特率：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" IsEnabled="False" Text="9600"/>

                <Label Grid.Row="4" Grid.Column="0" Content="校验位：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" IsEnabled="False" Text="NONE"/>

                <Button Grid.Row="6" Grid.ColumnSpan="2"
                        Name="Conect_Button"
                        Content="连接"
                        Width="220"
                        HorizontalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Button_Click_1"/>
            </Grid>
        </GroupBox>

        <!-- 右：电机控制 -->
        <GroupBox Grid.Column="2" Header="电机控制">
            <!-- 外层两行：上面表单(Auto) + 下面日志(*) -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ===== 上半部分：表单区 ===== -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 四列：标签 / 值 / 标签 / 值（用 Auto + *，不要写死像 140/160 那样） -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0：连接状态 + 当前角度 -->
                    <Label Grid.Row="0" Grid.Column="0" Content="连接状态：" HorizontalAlignment="Right" Margin="0,0,8,0"/>

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                        <Ellipse Height="22" Width="22" Margin="0,0,10,0">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop x:Name="Connection_Led" Color="Gray" Offset="1"/>
                                    <GradientStop Color="White" Offset="0"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlDarkColorKey}}"/>
                            </Ellipse.Stroke>
                        </Ellipse>
                    </StackPanel>

                    <Label Grid.Row="0" Grid.Column="2" Content="当前角度（°）：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource ValueCardStyle}">
                        <TextBlock Name="PositionText" HorizontalAlignment="Left"/>
                    </Border>

                    <!-- Row 2：温度 + 压力 -->
                    <Label Grid.Row="2" Grid.Column="0" Content="温度（℃）：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueCardStyle}" Margin="0,0,18,0">
                        <TextBlock Name="TempretureText" HorizontalAlignment="Left"/>
                    </Border>

                    <Label Grid.Row="2" Grid.Column="2" Content="压力（Bar）：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Border Grid.Row="2" Grid.Column="3" Style="{StaticResource ValueCardStyle}">
                        <TextBlock Name="PresureText" HorizontalAlignment="Left"/>
                    </Border>

                    <!-- Row 4：目标角度 + 打开激光 -->
                    <Label Grid.Row="4" Grid.Column="0" Content="目标位置（°）：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Name="Angle_Text" IsEnabled="False" Text="0" Margin="0,0,18,0"/>

                    <Button Grid.Row="4" Grid.Column="3"
                    Name="Laser_Switch"
                    IsEnabled="False"
                    Content="打开激光"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Switch_Laser"/>

                    <!-- Row 6：亮度 + 调光 -->
                    <Label Grid.Row="6" Grid.Column="0" Content="亮度：" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Name="Limit_Small_Text" IsEnabled="False" Text="0" Margin="0,0,18,0"/>

                    <Button Grid.Row="6" Grid.Column="2"
                    Name="Save_Limit_Btn"
                            IsEnabled="False"
                    Content="调光"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Click="Save_Limit"/>

                    <!-- Row 8：底部按钮（用 UniformGrid 更整齐，绝不挤/重叠） -->
                    <UniformGrid Grid.Row="8" Grid.ColumnSpan="4" Columns="2" Margin="0,6,0,0">
                        <Button Name="Target_Btn"
                        Content="目标位置"
                        IsEnabled="False"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,10,0"
                        Click="Go_Target"/>

                        <Button Name="Mode_Select_Btn"
                        Content="间隔触发"
                        IsEnabled="False"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Button_Click"/>
                    </UniformGrid>
                </Grid>

            </Grid>
        </GroupBox>

    </Grid>
</Window>
