############################
# Build results
############################
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
build/
publish/
artifacts/

############################
# Visual Studio
############################
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser

############################
# JetBrains Rider / ReSharper
############################
.idea/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

############################
# VS Code
############################
.vscode/

############################
# NuGet
############################
*.nupkg
*.snupkg
packages/
!packages/build/
!packages/repositories.config
.nuget/

############################
# Test / Coverage
############################
[Tt]est[Rr]esult*/
[Bb]enchmark[Dd]ot[Nn]et.Artifacts/
*.trx
*.coverage
*.coveragexml

############################
# Logs / Temp
############################
*.log
*.tlog
*.tmp
*.temp
*.cache

############################
# Generated files
############################
Generated/
AutoGenerated/

############################
# Publish / Installer output
############################
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt

############################
# Local app config / secrets
# 注意：如果这些文件里有本机配置、密码、token，就忽略
############################
appsettings.Development.json
appsettings.Local.json
*.env
.env
.env.*

############################
# OS files
############################
Thumbs.db
Desktop.ini
.DS_Store

############################
# ClickOnce / old VS related
############################
publish.htm

############################
# SQL / LocalDB / MDF
# 如果你确实需要把数据库文件纳入版本管理，请删除这一段
############################
*.mdf
*.ldf

############################
# Azure / tooling temp
############################
.csx/
.eco/